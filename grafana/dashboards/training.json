          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT DATE(start_time AT TIME ZONE 'Europe/Vienna') AS time, ROUND(SUM(CASE WHEN avg_hr IS NOT NULL AND duration_s IS NOT NULL AND duration_s > 0 THEN (duration_s/60.0) * LEAST(1.0,GREATEST(0.0,(avg_hr-60.0)/130.0)) * (0.64*EXP(1.92*LEAST(1.0,GREATEST(0.0,(avg_hr-60.0)/130.0)))) ELSE 0 END)::numeric, 1) AS \"Strength\" FROM workouts WHERE $__timeFilter(start_time) AND (name ILIKE '%kraft%' OR name ILIKE '%strength%') GROUP BY DATE(start_time AT TIME ZONE 'Europe/Vienna') ORDER BY time",
          "format": "time_series"
        },
        {
          "refId": "B",
          "rawSql": "SELECT DATE(start_time AT TIME ZONE 'Europe/Vienna') AS time, ROUND(SUM(CASE WHEN avg_hr IS NOT NULL AND duration_s IS NOT NULL AND duration_s > 0 THEN (duration_s/60.0) * LEAST(1.0,GREATEST(0.0,(avg_hr-60.0)/130.0)) * (0.64*EXP(1.92*LEAST(1.0,GREATEST(0.0,(avg_hr-60.0)/130.0)))) ELSE 0 END)::numeric, 1) AS \"Walking\" FROM workouts WHERE $__timeFilter(start_time) AND (name ILIKE '%walk%' OR name ILIKE '%spazier%' OR name ILIKE '%wander%' OR name ILIKE '%hik%') GROUP BY DATE(start_time AT TIME ZONE 'Europe/Vienna') ORDER BY time",
          "format": "time_series"
        },
        {
          "refId": "C",
          "rawSql": "SELECT DATE(start_time AT TIME ZONE 'Europe/Vienna') AS time, ROUND(SUM(CASE WHEN avg_hr IS NOT NULL AND duration_s IS NOT NULL AND duration_s > 0 THEN (duration_s/60.0) * LEAST(1.0,GREATEST(0.0,(avg_hr-60.0)/130.0)) * (0.64*EXP(1.92*LEAST(1.0,GREATEST(0.0,(avg_hr-60.0)/130.0)))) ELSE 0 END)::numeric, 1) AS \"Cycling\" FROM workouts WHERE $__timeFilter(start_time) AND (name ILIKE '%cycl%' OR name ILIKE '%radfahren%' OR name ILIKE '%fahrrad%') GROUP BY DATE(start_time AT TIME ZONE 'Europe/Vienna') ORDER BY time",
          "format": "time_series"
        }
      ]
    },
