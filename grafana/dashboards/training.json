          "rawSql": "SELECT TO_CHAR(w.start_time AT TIME ZONE '$tz', 'YYYY-MM-DD HH24:MI') AS \"Date\", w.name AS \"Type\", COALESCE(g.group_name, '—') AS \"Group\", ROUND(w.duration_s/60.0)::int AS \"Duration (min)\", ROUND(w.active_energy_kcal::numeric, 0) AS \"Energy (kcal)\", ROUND(w.avg_hr::numeric, 0) AS \"Avg HR (bpm)\", ROUND(w.max_hr::numeric, 0) AS \"Max HR (bpm)\", ROUND(w.distance_km::numeric, 2) AS \"Distance (km)\" FROM workouts w LEFT JOIN workout_type_groups g ON g.canonical_type = w.canonical_type WHERE $__timeFilter(w.start_time) ORDER BY w.start_time DESC",
