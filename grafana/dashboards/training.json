    {
      "id": 12,
      "type": "table",
      "title": "Training Findings",
      "description": "Automatically detected training patterns. training_load: Acute:Chronic Workload Ratio (ACWR = 7d load / 28d avg); > 1.5 = high injury risk, < 0.8 = undertraining. recovery_alert: combined z-scores of Resting HR and HRV; positive z means HR is elevated or HRV is suppressed relative to your baseline. anomaly: z-score deviation (σ) from personal baseline for any training metric.",
      "gridPos": {
        "x": 0,
        "y": 40,
        "w": 24,
        "h": 6
      },
      "datasource": {
        "uid": "healthlog-db"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "sortBy": [
          {
            "displayName": "Date",
            "desc": true
          }
        ],
        "footer": {
          "show": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT TO_CHAR(COALESCE(ref_date, window_end), 'YYYY-MM-DD') AS \"Date\", kind AS \"Kind\", metric_a AS \"Metric\", CASE kind WHEN 'anomaly' THEN ROUND((details->>'z')::numeric,1)::text || 'σ (val: ' || ROUND((details->>'value')::numeric,2)::text || ')' WHEN 'training_load' THEN 'ACWR ' || ROUND((details->>'ratio')::numeric,2)::text WHEN 'consistency' THEN ROUND((details->>'std_hours')::numeric,2)::text || 'h std' WHEN 'recovery_alert' THEN 'RHR z=' || ROUND((details->>'resting_heart_rate_z')::numeric,1)::text || ' HRV z=' || ROUND((details->>'heart_rate_variability_z')::numeric,1)::text WHEN 'correlation' THEN 'r=' || ROUND(coefficient::numeric,2)::text || ' lag=' || COALESCE(lag_days::text,'0') || 'd' ELSE ROUND(severity::numeric,2)::text END AS \"Detail\", note AS \"Note\" FROM findings WHERE kind IN ('training_load', 'recovery_alert', 'anomaly') ORDER BY COALESCE(ref_date, window_end) DESC LIMIT 50",
          "format": "table"
        }
      ]
    }
