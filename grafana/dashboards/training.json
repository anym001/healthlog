{
  "id": null,
  "uid": "healthlog-training",
  "title": "Training & Erholung",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "Europe/Vienna",
  "tags": ["healthlog"],
  "time": {"from": "now-30d", "to": "now"},
  "timepicker": {},
  "refresh": "5m",
  "panels": [
    {
      "id": 1,
      "type": "barchart",
      "title": "Trainingsbelastung (TRIMP)",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "postgres", "uid": "healthlog-db"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "healthlog-db"},
          "rawSql": "SELECT day AS time, sum AS \"TRIMP gesamt\" FROM daily_metrics WHERE metric = 'workout_trimp' AND $__timeFilter(day::timestamptz) ORDER BY day",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 2,
      "type": "barchart",
      "title": "Belastung nach Sportart",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "postgres", "uid": "healthlog-db"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "healthlog-db"},
          "rawSql": "SELECT day AS time, sum AS \"Krafttraining\" FROM daily_metrics WHERE metric = 'workout_trimp_krafttraining' AND $__timeFilter(day::timestamptz) ORDER BY day",
          "format": "time_series"
        },
        {
          "refId": "B",
          "datasource": {"type": "postgres", "uid": "healthlog-db"},
          "rawSql": "SELECT day AS time, sum AS \"Gehen\" FROM daily_metrics WHERE metric = 'workout_trimp_gehen' AND $__timeFilter(day::timestamptz) ORDER BY day",
          "format": "time_series"
        },
        {
          "refId": "C",
          "datasource": {"type": "postgres", "uid": "healthlog-db"},
          "rawSql": "SELECT day AS time, sum AS \"Radfahren\" FROM daily_metrics WHERE metric = 'workout_trimp_radfahren' AND $__timeFilter(day::timestamptz) ORDER BY day",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "stacking": "normal"
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "HRV & Ruhepuls",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "datasource": {"type": "postgres", "uid": "healthlog-db"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "healthlog-db"},
          "rawSql": "SELECT day AS time, avg AS \"HRV (ms)\" FROM daily_metrics WHERE metric = 'heart_rate_variability' AND $__timeFilter(day::timestamptz) ORDER BY day",
          "format": "time_series"
        },
        {
          "refId": "B",
          "datasource": {"type": "postgres", "uid": "healthlog-db"},
          "rawSql": "SELECT day AS time, vmin AS \"Ruhepuls (bpm)\" FROM daily_metrics WHERE metric = 'resting_heart_rate' AND $__timeFilter(day::timestamptz) ORDER BY day",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Ruhepuls (bpm)"},
            "properties": [
              {"id": "custom.axisPlacement", "value": "right"}
            ]
          }
        ]
      },
      "options": {}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Herzfrequenz-Erholung",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "datasource": {"type": "postgres", "uid": "healthlog-db"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "healthlog-db"},
          "rawSql": "SELECT day AS time, avg AS \"HF-Erholung (bpm)\" FROM daily_metrics WHERE metric = 'cardio_recovery' AND $__timeFilter(day::timestamptz) ORDER BY day",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 5,
      "type": "table",
      "title": "Workouts",
      "gridPos": {"x": 0, "y": 16, "w": 24, "h": 7},
      "datasource": {"type": "postgres", "uid": "healthlog-db"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "healthlog-db"},
          "rawSql": "SELECT DATE(start_time AT TIME ZONE 'Europe/Vienna') AS \"Datum\", name AS \"Sportart\", ROUND((duration_s/60)::numeric, 0) AS \"Dauer (min)\", ROUND(active_energy_kcal::numeric, 0) AS \"Energie (kcal)\", ROUND(avg_hr::numeric, 0) AS \"Ø HR (bpm)\", ROUND(distance_km::numeric, 2) AS \"Distanz (km)\" FROM workouts WHERE $__timeFilter(start_time) ORDER BY start_time DESC",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 6,
      "type": "table",
      "title": "Training-Befunde",
      "gridPos": {"x": 0, "y": 23, "w": 24, "h": 7},
      "datasource": {"type": "postgres", "uid": "healthlog-db"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "healthlog-db"},
          "rawSql": "SELECT ref_date AS \"Datum\", kind AS \"Art\", note AS \"Hinweis\", ROUND(severity::numeric, 2) AS \"Schweregrad\" FROM findings WHERE kind IN ('training_load', 'recovery_alert') AND ref_date >= NOW() - INTERVAL '30 days' ORDER BY ref_date DESC",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    }
  ],
  "templating": {"list": []},
  "annotations": {"list": []},
  "links": []
}
