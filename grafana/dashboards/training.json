{
  "uid": "healthlog-training",
  "title": "HealthLog – Training",
  "description": "30-day training load, recovery metrics, and workout history. Adjust HR Base and HR Reserve to match your physiology for accurate TRIMP values. Adjust Timezone if you are not in Europe/Vienna.",
  "schemaVersion": 39,
  "version": 2,
  "timezone": "Europe/Vienna",
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "refresh": "",
  "tags": [
    "healthlog"
  ],
  "links": [
    {
      "title": "Overview",
      "url": "/d/healthlog-overview",
      "type": "link",
      "icon": "external link",
      "keepTime": true,
      "targetBlank": false,
      "includeVars": false,
      "tooltip": "Open Overview dashboard"
    },
    {
      "title": "Sleep",
      "url": "/d/healthlog-sleep",
      "type": "link",
      "icon": "external link",
      "keepTime": true,
      "targetBlank": false,
      "includeVars": false,
      "tooltip": "Open Sleep dashboard"
    },
    {
      "title": "Metrics Explorer",
      "url": "/d/healthlog-metrics",
      "type": "link",
      "icon": "external link",
      "keepTime": true,
      "targetBlank": false,
      "includeVars": false,
      "tooltip": "Open Metrics Explorer"
    }
  ],
  "templating": {
    "list": [
      {
        "name": "tz",
        "type": "custom",
        "label": "Timezone",
        "description": "Timezone used to group workouts by local date and to display workout timestamps. Must match a valid PostgreSQL timezone name.",
        "query": "Europe/Vienna,Europe/Berlin,Europe/London,America/New_York,America/Los_Angeles,UTC",
        "current": {
          "value": "Europe/Vienna",
          "text": "Europe/Vienna"
        },
        "options": [
          {"text": "Europe/Vienna", "value": "Europe/Vienna", "selected": true},
          {"text": "Europe/Berlin", "value": "Europe/Berlin", "selected": false},
          {"text": "Europe/London", "value": "Europe/London", "selected": false},
          {"text": "America/New_York", "value": "America/New_York", "selected": false},
          {"text": "America/Los_Angeles", "value": "America/Los_Angeles", "selected": false},
          {"text": "UTC", "value": "UTC", "selected": false}
        ],
        "hide": 0,
        "multi": false,
        "includeAll": false,
        "sort": 0,
        "refresh": 0
      },
      {
        "name": "hr_rest",
        "type": "textbox",
        "label": "HR Base (bpm)",
        "description": "Resting heart rate baseline for the TRIMP formula (typically your morning resting HR).",
        "query": "60",
        "hide": 0
      },
      {
        "name": "hr_reserve",
        "type": "textbox",
        "label": "HR Reserve (bpm)",
        "description": "Heart rate reserve = MaxHR − RestingHR. Example: if MaxHR = 190 and resting = 60, enter 130.",
        "query": "130",
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Weekly KPIs",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 1,
      "type": "stat",
      "title": "TRIMP (last 7d)",
      "description": "Training Impulse accumulated over the last 7 days. TRIMP = Σ (duration_min × HR-intensity × 0.64·e^(1.92·intensity)). Blue < 100 (light week), green 100–299, yellow 300–499, red ≥ 500 (very high load). Adjust HR Base and HR Reserve variables for accurate results.",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "uid": "healthlog-db"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "green",
                "value": 100
              },
              {
                "color": "yellow",
                "value": 300
              },
              {
                "color": "red",
                "value": 500
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT ROUND(SUM(CASE WHEN avg_hr IS NOT NULL AND duration_s IS NOT NULL AND duration_s > 0 THEN (duration_s/60.0) * LEAST(1.0,GREATEST(0.0,(avg_hr-${hr_rest}::numeric)/${hr_reserve}::numeric)) * (0.64*EXP(1.92*LEAST(1.0,GREATEST(0.0,(avg_hr-${hr_rest}::numeric)/${hr_reserve}::numeric)))) ELSE 0 END)::numeric, 0) AS \"TRIMP (7d)\" FROM workouts WHERE start_time >= NOW() - INTERVAL '7 days'",
          "format": "table"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Workouts (last 7d)",
      "description": "Number of workout sessions in the last 7 days. Blue < 3, green 3–5, yellow ≥ 6.",
      "gridPos": {
        "x": 6,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "uid": "healthlog-db"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "green",
                "value": 3
              },
              {
                "color": "yellow",
                "value": 6
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT COUNT(*)::integer AS \"Workouts\" FROM workouts WHERE start_time >= NOW() - INTERVAL '7 days'",
          "format": "table"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Last HRV",
      "description": "Latest daily HRV average (ms). Higher = better autonomic recovery. Yellow ≥ 30 ms, green ≥ 50 ms.",
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "uid": "healthlog-db"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 30
              },
              {
                "color": "green",
                "value": 50
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT avg AS \"HRV\" FROM daily_metrics WHERE metric = 'heart_rate_variability' ORDER BY day DESC LIMIT 1",
          "format": "table"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Last Resting HR",
      "description": "Latest daily resting heart rate minimum (bpm). Lower = better cardiovascular fitness. Yellow ≥ 65 bpm, red ≥ 75 bpm.",
      "gridPos": {
        "x": 18,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "uid": "healthlog-db"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "suffix:bpm",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 65
              },
              {
                "color": "red",
                "value": 75
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT vmin AS \"Resting HR\" FROM daily_metrics WHERE metric = 'resting_heart_rate' ORDER BY day DESC LIMIT 1",
          "format": "table"
        }
      ]
    },
    {
      "id": 101,
      "type": "row",
      "title": "Training Load",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 5,
      "type": "barchart",
      "title": "Training Load (TRIMP)",
      "description": "Daily total TRIMP. Formula: Σ (duration_min × intensity × 0.64·e^(1.92·intensity)) where intensity = LEAST(1, MAX(0, (AvgHR − HR Base) / HR Reserve)). Adjust the HR Base and HR Reserve variables above to match your physiology.",
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "uid": "healthlog-db"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 1,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {}
        },
        "overrides": []
      },
      "options": {
        "stacking": "none",
        "barRadius": 0.1,
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT DATE(start_time AT TIME ZONE '$tz') AS time, ROUND(SUM(CASE WHEN avg_hr IS NOT NULL AND duration_s IS NOT NULL AND duration_s > 0 THEN (duration_s/60.0) * LEAST(1.0,GREATEST(0.0,(avg_hr-${hr_rest}::numeric)/${hr_reserve}::numeric)) * (0.64*EXP(1.92*LEAST(1.0,GREATEST(0.0,(avg_hr-${hr_rest}::numeric)/${hr_reserve}::numeric)))) ELSE 0 END)::numeric, 1) AS \"TRIMP\" FROM workouts WHERE $__timeFilter(start_time) GROUP BY DATE(start_time AT TIME ZONE '$tz') ORDER BY time",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 6,
      "type": "barchart",
      "title": "Load by Sport",
      "description": "Daily TRIMP by sport group via workout_type_groups JOIN on canonical_type. Groups are defined in the workout_type_groups table — adding a new sport there automatically creates a new series here without any dashboard edits.",
      "gridPos": {
        "x": 12,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "uid": "healthlog-db"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 1,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {}
        },
        "overrides": []
      },
      "options": {
        "stacking": "normal",
        "barRadius": 0.1,
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "transformations": [
        {
          "id": "partitionByValues",
          "options": {
            "fields": ["sport_group"],
            "keepFields": false
          }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT DATE(w.start_time AT TIME ZONE '$tz') AS time, COALESCE(g.group_name, 'Other') AS sport_group, ROUND(SUM(CASE WHEN w.avg_hr IS NOT NULL AND w.duration_s IS NOT NULL AND w.duration_s > 0 THEN (w.duration_s/60.0) * LEAST(1.0,GREATEST(0.0,(w.avg_hr-${hr_rest}::numeric)/${hr_reserve}::numeric)) * (0.64*EXP(1.92*LEAST(1.0,GREATEST(0.0,(w.avg_hr-${hr_rest}::numeric)/${hr_reserve}::numeric)))) ELSE 0 END)::numeric, 1) AS trimp FROM workouts w LEFT JOIN workout_type_groups g ON g.canonical_type = w.canonical_type WHERE $__timeFilter(w.start_time) GROUP BY DATE(w.start_time AT TIME ZONE '$tz'), COALESCE(g.group_name, 'Other'), COALESCE(g.sort_order, 99) ORDER BY time, COALESCE(g.sort_order, 99), sport_group",
          "format": "table"
        }
      ]
    },
    {
      "id": 102,
      "type": "row",
      "title": "Recovery",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "HRV & Resting Heart Rate",
      "description": "HRV (left axis, ms): higher = better autonomic recovery. Resting HR (right axis, bpm): lower = better cardiovascular fitness. Dashed lines show 7-day moving averages.",
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "uid": "healthlog-db"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "spanNulls": false,
            "showPoints": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Resting HR (bpm)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "suffix:bpm"
              },
              {
                "id": "custom.axisPlacement",
                "value": "right"
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "HRV Trend (ms)"
            },
            "properties": [
              {
                "id": "color",
                "value": {"mode": "fixed", "fixedColor": "blue"}
              },
              {
                "id": "custom.lineStyle",
                "value": {"fill": "dash", "dash": [8, 4]}
              },
              {
                "id": "custom.lineWidth",
                "value": 1
              },
              {
                "id": "custom.fillOpacity",
                "value": 0
              },
              {
                "id": "custom.showPoints",
                "value": "never"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Resting HR Trend (bpm)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "suffix:bpm"
              },
              {
                "id": "custom.axisPlacement",
                "value": "right"
              },
              {
                "id": "color",
                "value": {"mode": "fixed", "fixedColor": "dark-orange"}
              },
              {
                "id": "custom.lineStyle",
                "value": {"fill": "dash", "dash": [8, 4]}
              },
              {
                "id": "custom.lineWidth",
                "value": 1
              },
              {
                "id": "custom.fillOpacity",
                "value": 0
              },
              {
                "id": "custom.showPoints",
                "value": "never"
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT day AS time, avg AS \"HRV (ms)\" FROM daily_metrics WHERE metric = 'heart_rate_variability' AND $__timeFilter(day::timestamptz) ORDER BY day",
          "format": "time_series"
        },
        {
          "refId": "B",
          "rawSql": "SELECT day AS time, vmin AS \"Resting HR (bpm)\" FROM daily_metrics WHERE metric = 'resting_heart_rate' AND $__timeFilter(day::timestamptz) ORDER BY day",
          "format": "time_series"
        },
        {
          "refId": "C",
          "rawSql": "SELECT day AS time, ROUND(AVG(avg) OVER (ORDER BY day ROWS BETWEEN 6 PRECEDING AND CURRENT ROW)::numeric, 0) AS \"HRV Trend (ms)\" FROM daily_metrics WHERE metric = 'heart_rate_variability' AND $__timeFilter(day::timestamptz) ORDER BY day",
          "format": "time_series"
        },
        {
          "refId": "D",
          "rawSql": "SELECT day AS time, ROUND(AVG(vmin) OVER (ORDER BY day ROWS BETWEEN 6 PRECEDING AND CURRENT ROW)::numeric, 0) AS \"Resting HR Trend (bpm)\" FROM daily_metrics WHERE metric = 'resting_heart_rate' AND $__timeFilter(day::timestamptz) ORDER BY day",
          "format": "time_series"
        }
      ]
    },
