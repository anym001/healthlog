    {
      "id": 10,
      "type": "timeseries",
      "title": "VO2 Max",
      "description": "Estimated VO2 Max (ml/kg/min). Higher = better aerobic capacity. Dashed line is the 7-day moving average.",
      "gridPos": {
        "x": 12,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "uid": "healthlog-db"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "suffix:ml/kg/min",
          "decimals": 1,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
