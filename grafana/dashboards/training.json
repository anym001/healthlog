      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT TO_CHAR(start_time AT TIME ZONE 'Europe/Vienna', 'YYYY-MM-DD HH24:MI') AS \"Date\", name AS \"Type\", ROUND(duration_s/60.0)::int AS \"Duration (min)\", ROUND(active_energy_kcal::numeric, 0) AS \"Energy (kcal)\", ROUND(avg_hr::numeric, 0) AS \"Avg HR (bpm)\", ROUND(max_hr::numeric, 0) AS \"Max HR (bpm)\", ROUND(distance_km::numeric, 2) AS \"Distance (km)\" FROM workouts WHERE $__timeFilter(start_time) ORDER BY start_time DESC",
