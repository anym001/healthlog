    {
      "id": 4,
      "type": "stat",
      "title": "Last Night – Sleep Efficiency",
      "description": "% of time in bed actually asleep. Calculated from in-bed timestamps when available, otherwise total_sleep / (sleep + awake). Yellow ≥ 75 %, green ≥ 85 %.",
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "uid": "healthlog-db"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 75
              },
              {
                "color": "green",
                "value": 85
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT sleep_date AS time, ROUND(efficiency_pct::numeric, 0) AS \"Sleep Efficiency\" FROM sleep_metrics WHERE $__timeFilter(sleep_date::timestamptz) ORDER BY sleep_date",
          "format": "time_series"
        }
      ]
    },
    {
