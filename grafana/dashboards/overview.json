  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Today at a Glance",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Last Night – Total Sleep",
      "description": "Total sleep duration for the most recent night. Yellow ≥ 6 h, green ≥ 7 h (WHO recommendation).",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "uid": "healthlog-db"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "suffix:h",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 6
              },
              {
                "color": "green",
                "value": 7
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT sleep_date AS time, total_sleep_h AS \"Total Sleep\" FROM sleep_nightly WHERE $__timeFilter(sleep_date::timestamptz) ORDER BY sleep_date",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Last Night – Deep Sleep",
      "description": "Deep (slow-wave) sleep for the most recent night. Yellow ≥ 0.8 h, green ≥ 1.2 h.",
      "gridPos": {
        "x": 4,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "uid": "healthlog-db"
      },
      "fieldConfig": {
        "defaults": {
