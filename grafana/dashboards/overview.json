      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT day AS time, avg AS \"HRV\" FROM daily_metrics WHERE metric = 'heart_rate_variability' AND $__timeFilter(day::timestamptz) ORDER BY day",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Today – Resting HR",
      "description": "Latest daily resting heart rate minimum (bpm). Lower = better cardiovascular fitness. Yellow ≥ 65 bpm, red ≥ 75 bpm.",
      "gridPos": {
