{
  "uid": "healthlog-overview",
  "title": "HealthLog – Overview",
  "description": "Daily health snapshot: last night's sleep, current HRV & resting heart rate, steps, active energy, and key findings. Time window: 14 days.",
  "schemaVersion": 39,
  "version": 4,
  "timezone": "Europe/Vienna",
  "time": {
    "from": "now-14d",
    "to": "now"
  },
  "refresh": "",
  "tags": [
    "healthlog"
  ],
  "links": [
    {
      "title": "Sleep",
      "url": "/d/healthlog-sleep",
      "type": "link",
      "icon": "external link",
      "keepTime": true,
      "targetBlank": false,
      "includeVars": false,
      "tooltip": "Open Sleep dashboard"
    },
    {
      "title": "Training",
      "url": "/d/healthlog-training",
      "type": "link",
      "icon": "external link",
      "keepTime": true,
      "targetBlank": false,
      "includeVars": false,
      "tooltip": "Open Training & Recovery dashboard"
    },
    {
      "title": "Metrics Explorer",
      "url": "/d/healthlog-metrics",
      "type": "link",
      "icon": "external link",
      "keepTime": true,
      "targetBlank": false,
      "includeVars": false,
      "tooltip": "Open Metrics Explorer"
    }
