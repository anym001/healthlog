      "title": "Sleep Phases",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "uid": "healthlog-db"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "suffix:h",
          "decimals": 1,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {}
        },
        "overrides": []
      },
      "options": {
        "stacking": "normal",
        "barRadius": 0.1,
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT sleep_date AS time, deep_h AS \"Deep\", core_h AS \"Core\", rem_h AS \"REM\", awake_h AS \"Awake\" FROM sleep_sessions WHERE $__timeFilter(sleep_date::timestamptz) ORDER BY sleep_date",
          "format": "time_series"
        }
      ]
    },
