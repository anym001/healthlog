{
  "uid": "healthlog-overview",
  "title": "HealthLog – Overview",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "Europe/Vienna",
  "time": {
    "from": "now-14d",
    "to": "now"
  },
  "refresh": "1h",
  "tags": [
    "healthlog"
  ],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Last Night – Total Sleep",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "uid": "healthlog-db"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "suffix:h",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 6
              },
              {
                "color": "green",
                "value": 7
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT total_sleep_h AS \"Total Sleep\" FROM sleep_sessions ORDER BY sleep_date DESC LIMIT 1",
          "format": "table"
        }
      ]
    },
