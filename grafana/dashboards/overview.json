      "description": "Latest daily HRV average (ms). Higher = better autonomic recovery. Yellow ≥ 30 ms, green ≥ 50 ms.",
      "gridPos": {
        "x": 16,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "uid": "healthlog-db"
      },
      "fieldConfig": {
