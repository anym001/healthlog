    {
      "id": 8,
      "type": "timeseries",
      "title": "Bedtime",
      "description": "Hour of sleep onset on a 20–30 scale (20 = 20:00, 24 = midnight, 26 = 02:00 next day). Uses the selected Timezone. Dashed line is the 7-day moving average.",
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "uid": "healthlog-db"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "spanNulls": false,
            "showPoints": "auto",
            "axisLabel": "Clock hour ($tz)"
          },
          "min": 20,
          "max": 30
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "7d Trend (h)"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {"fill": "dash", "dash": [8, 4]}
              },
              {
                "id": "custom.lineWidth",
                "value": 1
