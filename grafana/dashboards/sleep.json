    {
      "id": 4,
      "type": "stat",
      "title": "Avg Sleep Efficiency (7d)",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "uid": "healthlog-db"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 75
              },
              {
                "color": "green",
                "value": 85
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT ROUND(AVG(total_sleep_h / NULLIF(CASE WHEN in_bed_start IS NOT NULL AND in_bed_end IS NOT NULL THEN EXTRACT(EPOCH FROM (in_bed_end - in_bed_start))/3600.0 WHEN in_bed_h > 0 THEN in_bed_h WHEN (total_sleep_h + awake_h) > 0 THEN total_sleep_h + awake_h ELSE NULL END, 0.0) * 100)::numeric, 0) AS \"Avg Sleep Efficiency\" FROM sleep_sessions WHERE sleep_date >= CURRENT_DATE - INTERVAL '7 days'",
          "format": "table"
        }
      ]
    },
    {
      "id": 5,
      "type": "barchart",
      "title": "Sleep Phases",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 9
      },
      "datasource": {
        "uid": "healthlog-db"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "suffix:h",
          "decimals": 1,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {}
        },
        "overrides": []
      },
      "options": {
        "stacking": "normal",
        "barRadius": 0.1,
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT sleep_date AS time, deep_h AS \"Deep\", core_h AS \"Core\", rem_h AS \"REM\", awake_h AS \"Awake\" FROM sleep_sessions WHERE $__timeFilter(sleep_date::timestamptz) ORDER BY sleep_date",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Sleep Duration",
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "uid": "healthlog-db"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "suffix:h",
          "decimals": 1,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "spanNulls": false,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT sleep_date AS time, total_sleep_h AS \"Total Sleep (h)\" FROM sleep_sessions WHERE $__timeFilter(sleep_date::timestamptz) ORDER BY sleep_date",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Sleep Efficiency",
      "gridPos": {
        "x": 12,
        "y": 13,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "uid": "healthlog-db"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "spanNulls": false,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT sleep_date AS time, (total_sleep_h / NULLIF(CASE WHEN in_bed_start IS NOT NULL AND in_bed_end IS NOT NULL THEN EXTRACT(EPOCH FROM (in_bed_end - in_bed_start))/3600.0 WHEN in_bed_h > 0 THEN in_bed_h WHEN (total_sleep_h + awake_h) > 0 THEN total_sleep_h + awake_h ELSE NULL END, 0.0) * 100) AS \"Sleep Efficiency (%)\" FROM sleep_sessions WHERE $__timeFilter(sleep_date::timestamptz) ORDER BY sleep_date",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Bedtime",
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "uid": "healthlog-db"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "spanNulls": false,
            "showPoints": "auto",
            "axisLabel": "Clock hour (Vienna)"
          },
          "min": 20,
          "max": 30
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT sleep_date AS time, EXTRACT(HOUR FROM (sleep_start AT TIME ZONE 'Europe/Vienna')) + EXTRACT(MINUTE FROM (sleep_start AT TIME ZONE 'Europe/Vienna'))/60.0 + CASE WHEN EXTRACT(HOUR FROM (sleep_start AT TIME ZONE 'Europe/Vienna')) < 12 THEN 24 ELSE 0 END AS \"Bedtime (h)\" FROM sleep_sessions WHERE $__timeFilter(sleep_date::timestamptz) AND sleep_start IS NOT NULL ORDER BY sleep_date",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Wake-up Time",
      "gridPos": {
        "x": 12,
        "y": 21,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "uid": "healthlog-db"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "spanNulls": false,
            "showPoints": "auto",
            "axisLabel": "Clock hour (Vienna)"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT sleep_date AS time, EXTRACT(HOUR FROM (sleep_end AT TIME ZONE 'Europe/Vienna')) + EXTRACT(MINUTE FROM (sleep_end AT TIME ZONE 'Europe/Vienna'))/60.0 AS \"Wake-up (h)\" FROM sleep_sessions WHERE $__timeFilter(sleep_date::timestamptz) AND sleep_end IS NOT NULL ORDER BY sleep_date",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 10,
      "type": "table",
      "title": "Sleep Findings",
      "gridPos": {
        "x": 0,
        "y": 29,
        "w": 24,
        "h": 7
      },
      "datasource": {
        "uid": "healthlog-db"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "sortBy": [
          {
            "displayName": "Date",
            "desc": true
          }
        ],
        "footer": {
          "show": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT TO_CHAR(COALESCE(ref_date, window_end), 'YYYY-MM-DD') AS \"Date\", kind AS \"Kind\", metric_a AS \"Metric\", CASE kind WHEN 'anomaly' THEN ROUND((details->>'z')::numeric,1)::text || 'σ (val: ' || ROUND((details->>'value')::numeric,2)::text || ')' WHEN 'training_load' THEN 'ACWR ' || ROUND((details->>'ratio')::numeric,2)::text WHEN 'consistency' THEN ROUND((details->>'std_hours')::numeric,2)::text || 'h std' WHEN 'recovery_alert' THEN 'RHR z=' || ROUND((details->>'resting_heart_rate_z')::numeric,1)::text || ' HRV z=' || ROUND((details->>'heart_rate_variability_z')::numeric,1)::text WHEN 'correlation' THEN 'r=' || ROUND(coefficient::numeric,2)::text || ' lag=' || COALESCE(lag_days::text,'0') || 'd' ELSE ROUND(severity::numeric,2)::text END AS \"Detail\", note AS \"Note\" FROM findings WHERE kind IN ('consistency', 'anomaly') AND (metric_a LIKE 'sleep%' OR metric_a = 'bedtime') ORDER BY COALESCE(ref_date, window_end) DESC LIMIT 50",
          "format": "table"
        }
      ]
    }
  ]
}