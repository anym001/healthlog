{
  "uid": "healthlog-sleep",
  "title": "HealthLog – Sleep",
  "description": "30-day sleep analysis: phases, duration, efficiency, bedtime consistency, and sleep-related findings. Adjust the Timezone variable if you are not in Europe/Vienna.",
  "schemaVersion": 39,
  "version": 2,
  "timezone": "Europe/Vienna",
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "refresh": "",
  "tags": [
    "healthlog"
  ],
  "links": [
    {
      "title": "Overview",
      "url": "/d/healthlog-overview",
      "type": "link",
      "icon": "external link",
      "keepTime": true,
      "targetBlank": false,
      "includeVars": false,
      "tooltip": "Open Overview dashboard"
    },
    {
      "title": "Training",
      "url": "/d/healthlog-training",
      "type": "link",
      "icon": "external link",
      "keepTime": true,
      "targetBlank": false,
      "includeVars": false,
      "tooltip": "Open Training & Recovery dashboard"
    },
    {
      "title": "Metrics Explorer",
