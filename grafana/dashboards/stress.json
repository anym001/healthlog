{
  "uid": "healthlog-stress",
  "title": "HealthLog – Stress",
  "description": "Garmin-style stress proxy from Apple Health heart-rate + HRV. Derived, not measured: Apple Health exports no RR intervals, so this tracks your own baseline over time and is not comparable to a Garmin/Firstbeat value.",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "Europe/Vienna",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "refresh": "",
  "tags": [
    "healthlog"
  ],
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "Stress Score — latest day",
      "description": "Overall daily stress (0-100), most recent day in range. A derived proxy from the heart-rate elevation above your resting baseline (workouts excluded), HRV-calibrated — NOT a Garmin value. Blue rest < 25, green low < 50, orange medium < 75, red high.",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 8
      },
      "datasource": {
        "uid": "healthlog-db"
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "none",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "green",
                "value": 25
              },
              {
                "color": "orange",
                "value": 50
              },
              {
                "color": "red",
                "value": 75
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT day AS time, score AS \"Stress Score\" FROM stress_daily WHERE $__timeFilter(day::timestamptz) ORDER BY day",
          "format": "time_series",
          "datasource": {
            "uid": "healthlog-db"
          }
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Time in stress zones (per day)",
      "description": "Minutes per day in each stress zone, plus workout (Active) minutes. Stacked bars.",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 18,
        "h": 8
      },
      "datasource": {
        "uid": "healthlog-db"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "m",
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 80,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Rest"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Low"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Medium"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "High"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Active"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "purple"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT day AS time, rest_min AS \"Rest\", low_min AS \"Low\", medium_min AS \"Medium\", high_min AS \"High\", active_min AS \"Active\" FROM stress_daily WHERE $__timeFilter(day::timestamptz) ORDER BY day",
          "format": "time_series",
          "datasource": {
            "uid": "healthlog-db"
          }
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Intraday stress timeline",
      "description": "Per-bucket stress (0-100) over the selected range, coloured by zone. Gaps are unmeasured (watch off / workout). For a usable timeline set Health Auto Export's Time Grouping to Minute.",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 24,
        "h": 9
      },
      "datasource": {
        "uid": "healthlog-db"
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "none",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "green",
                "value": 25
              },
              {
                "color": "orange",
                "value": 50
              },
              {
                "color": "red",
                "value": 75
              }
            ]
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 1,
            "fillOpacity": 40,
            "gradientMode": "scheme",
            "spanNulls": false,
            "showPoints": "never",
            "thresholdsStyle": {
              "mode": "off"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT (EXTRACT(EPOCH FROM ts) * 1000)::bigint AS \"Time\", stress AS \"Stress\" FROM stress_intraday WHERE $__timeFilter(ts) AND stress IS NOT NULL ORDER BY ts",
          "format": "time_series",
          "datasource": {
            "uid": "healthlog-db"
          }
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Daily stress score — trend",
      "description": "Overall daily stress score over time. Interpret relative to your own baseline, not Garmin.",
      "gridPos": {
        "x": 0,
        "y": 17,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "uid": "healthlog-db"
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "none",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "green",
                "value": 25
              },
              {
                "color": "orange",
                "value": 50
              },
              {
                "color": "red",
                "value": 75
              }
            ]
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "spanNulls": true,
            "showPoints": "auto",
            "pointSize": 5
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT day AS time, score AS \"Stress Score\" FROM stress_daily WHERE $__timeFilter(day::timestamptz) ORDER BY day",
          "format": "time_series",
          "datasource": {
            "uid": "healthlog-db"
          }
        }
      ]
    }
  ]
}
