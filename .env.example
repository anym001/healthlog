# Copy to .env and adjust. Compose reads these.

# Strong random secret expected in the HAE request header (X-Ingest-Token).
INGEST_SECRET=change-me-to-a-long-random-string

# TimescaleDB password.
DB_PASSWORD=healthlog

# Local timezone for daily aggregation (must match your locale).
LOCAL_TZ=Europe/Vienna

# When the nightly analysis runs (in LOCAL_TZ), as a 5-field cron expression.
ANALYSIS_CRON=30 3 * * *

# Container ownership of /config (Unraid: 99 / 100).
PUID=1000
PGID=1000

# Logging.
LOG_LEVEL=INFO
LOG_FORMAT=text

# Grafana admin password.
GRAFANA_PASSWORD=admin
