# HealthLog compose configuration. Copy to `.env` (docker compose reads it
# automatically) and set the two required values. Never commit your `.env`.

# --- Required -------------------------------------------------------------

# Password of the `healthlog` database user (any strong random string).
POSTGRES_PASSWORD=

# Shared secret Health Auto Export sends in the X-Ingest-Token header.
# Generate one: openssl rand -hex 32
INGEST_SECRET=

# --- Optional (defaults shown) ---------------------------------------------

# Container clock AND the timezone the daily analysis grid is computed in —
# must match your locale (see README "Configuration").
#TZ=Europe/Vienna

# When the nightly analysis runs (5-field cron, in TZ).
#ANALYSIS_CRON=30 3 * * *

# Host user/group that owns /config (Unraid: 99 / 100).
#PUID=1000
#PGID=1000

# Host directory mounted at /config (config.yaml, import/, narration/, logs).
#CONFIG_DIR=./config

# Pin production to a fixed release, e.g. 0.2.0 (see README "Image").
#HEALTHLOG_VERSION=latest

# Gotify/PushBits application token for push notifications (the one notify
# secret; behaviour is configured under `notify:` in config.yaml).
#NOTIFY_TOKEN=

# Expose the Prometheus /metrics endpoint (unauthenticated — trusted networks
# only; see README "Metrics").
#METRICS_ENABLED=false
