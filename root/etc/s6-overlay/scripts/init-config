#!/command/with-contenv bash
# Adjust the app user to the requested PUID/PGID and own /config, so the
# bind-mounted state (logs, future backups) gets the correct host permissions.
set -euo pipefail

PUID="${PUID:-1000}"
PGID="${PGID:-1000}"

echo "init-config: applying PUID=${PUID} PGID=${PGID}"
groupmod -o -g "${PGID}" healthlog
usermod -o -u "${PUID}" -g "${PGID}" healthlog

# /config/import is the drop folder for the bulk-backfill CLI; created up
# front so operators never have to mkdir it by hand.
mkdir -p /config /config/logs /config/import
chown -R healthlog:healthlog /config
